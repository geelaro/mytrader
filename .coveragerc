[run]
source = .
omit =
    # Tests themselves
    tests/*
    # Streamlit dashboard layer — hard to unit-test without a session
    dashboard/*
    # One-off scripts (not part of the runtime engine)
    scripts/*
    # Generated / vendored / non-code
    htmlcov/*
    .venv/*
    archive/*
    # Repository hygiene files
    setup.py
    conftest.py

[report]
# Lines that are conventionally exempt from coverage
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
precision = 1
show_missing = false
skip_covered = true
